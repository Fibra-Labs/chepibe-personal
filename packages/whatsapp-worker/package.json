    "prepublishOnly": "pnpm build",
    "start": "node dist/main.mjs",
    "lint": "oxlint src/"
  },
  "dependencies": {
    "@chepibe-personal/shared": "workspace:*",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "groq-sdk": "^0.37.0",
    "node-cache": "^5.1.2",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}