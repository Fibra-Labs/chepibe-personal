# Your WhatsApp number (country code + number, no + sign)
# Example: 5491171234567 (Argentina), 14155552671 (US)
ALLOWED_PHONE=

# Groq AI
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3
GROQ_LLM_MODEL=llama-3.1-8b-instant

# Database (local file or Turso)
DATABASE_URL=file:../../data/chepibe-personal.db
DATABASE_PASSWORD=

# Web
WEB_PORT=3000

# Debug - enables Baileys connection logging. We NEVER log user messages, transcripts, or summaries.
# Only metadata (message IDs, timestamps, buffer sizes) is ever logged. The Groq SDK debug logger
# (which would dump transcription text and your API key) is always suppressed regardless of this setting.
# Set DEBUG=true only for local development troubleshooting of connection issues.
DEBUG=false

# Node
NODE_ENV=development
