# Your WhatsApp number (country code + number, no + sign)
# Example: 5491171234567 (Argentina), 14155552671 (US)
ALLOWED_PHONE=

# Groq AI
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3
GROQ_LLM_MODEL=llama-3.1-8b-instant

# Worker
WORKER_PORT=3001

# Web
WEB_PORT=3000
WORKER_API_URL=http://localhost:3001

# Debug - this will NOT log any incoming user messages, ever, even if set to TRUE.
DEBUG=false

# Node
NODE_ENV=development
